# claude-code-bridge configuration
# Copy this to .env and adjust as needed

# Port for the bridge proxy server
BRIDGE_PORT=18793

# Claude Code model to use
# Aliases always resolve to the latest snapshot of each family:
#   sonnet     — Claude Sonnet (recommended, balanced)
#   opus       — Claude Opus (most capable)
#   haiku      — Claude Haiku (fastest, cheapest)
#   fable      — Claude Fable (latest flagship)
# Full IDs also work, e.g. claude-opus-4-8, claude-sonnet-4-6, claude-fable-5
CLAUDE_MODEL=sonnet

# Path to claude binary (default: auto-detect from PATH)
# CLAUDE_BIN=/usr/local/bin/claude

# Tool mode: agent (default) or llm
#
# agent — Claude Code runs as a full AI agent with all built-in tools
#   (Read, Write, Edit, Bash, WebSearch, …) and --dangerously-skip-permissions.
#   File operations execute on the bridge host. Best for single-machine use.
#
# llm   — Disables every built-in tool (--tools ""). Claude behaves as a pure
#   language model with no filesystem access. Required when the bridge is shared
#   across machines: callers must include file content in the prompt themselves
#   (same model as any cloud LLM API — the AI will ask you to paste the file if
#   it needs it).
#
# BRIDGE_TOOL_MODE=llm

# Permission mode: bypassPermissions (default), plan, default
# Only applies in agent mode (ignored when BRIDGE_TOOL_MODE=llm).
# 'bypassPermissions' = skip all permission prompts (recommended for bridge mode)
CLAUDE_PERMISSION_MODE=bypassPermissions

# Working directory for claude (default: $HOME)
# CLAUDE_WORKING_DIR=/home/you/projects

# Request timeout in milliseconds (default: 5 minutes)
# BRIDGE_TIMEOUT_MS=300000

# Verbose logging: log full request/response bodies and claude-cli I/O
# Set to false to reduce log verbosity
# BRIDGE_VERBOSE=true

# Anthropic API key — enables live model list via GET /v1/models
# Without this, a hardcoded list of known models is used instead.
# Only needed for model discovery; Claude Code CLI uses its own OAuth auth.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional bearer auth (v1.3). When set, every endpoint except /health requires
#   Authorization: Bearer <key>   (OpenAI SDK style), or
#   x-api-key: <key>              (Anthropic SDK style)
# Leave unset for localhost-only use; set it before exposing the bridge on a
# LAN / Tailscale network. Generate one with: openssl rand -hex 32
# BRIDGE_API_KEY=
